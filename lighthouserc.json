{
  "ci": {
    "collect": {
      "numberOfRuns": 1,
      "settings": {
        "formFactor": "mobile",
        "screenEmulation": { "mobile": true },
        "throttling": {
          "rttMs": 150,
          "throughputKbps": 1638.4,
          "cpuSlowdownMultiplier": 4
        }
      }
    },
    "assert": {
      "assertions": {
        "categories:performance": ["error", { "minScore": 0.9 }],
        "categories:accessibility": ["error", { "minScore": 1 }],
        "categories:best-practices": ["error", { "minScore": 0.95 }]
      }
    }
  }
}
